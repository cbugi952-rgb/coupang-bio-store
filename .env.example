# 이 파일을 복사해서 .env.local 로 만들고 값을 채운다 (로컬 vercel dev 용).
# 실제 배포는 Vercel 프로젝트 → Settings → Environment Variables 에 동일하게 설정.

# 관리자 비밀번호 (관리자 페이지에서 '게시'할 때 필요)
ADMIN_PASSWORD=change-me

# 아래 둘은 Vercel에서 Upstash(Redis) 스토리지를 연결하면 자동으로 주입된다.
# 로컬에서 vercel dev 를 쓸 땐  vercel env pull .env.local  로 받아온다.
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
